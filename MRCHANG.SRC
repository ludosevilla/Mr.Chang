// Types defs

type tpole {
	byte state;//0: no pole/16:x1pole/32:x2pole/48:x3pole (height of pole)
	nat posTileDown; //Pos of first tile (bottom) of pole
	byte animState; // for animation
	byte plateNum; //plate num if plate on top (100:no plate) 
	nat X; // X coord
	nat Y; // Y coord (bottom)
	
};

type tplayer {
	int X;
	int Y;
	nat pathList; //Address of path list 
	byte pathDir;// Path direction 0:none 1:left 2:right
	byte pathStep;// Current index in path array
	byte pathMax;// Max index in path array
	byte plateCatched;
	byte spId; // Will be 0
	byte spRef;
};

type twitch {
	byte level; // 0 (ground) to 2 (top)
	byte side; // 0: left 1: right
	byte state; //0:not present 1:head 2:body
	bool willShot;// true if witch will shot
	nat showTime;// time when witch appeared
	nat shootTime;// when witch will shot
	
	// Each witch could have a different design
	// sprite id from 1 to 12
	byte spIdHead1;// Head only
	byte spIdHead2;// Head with body
	byte spIdBody;
	byte spRefHead1;
	byte spRefHead2;
	byte spRefBody;
};
	

type tweapon {
	byte wtype;
	int X;
	int Y;
	byte dir;//direction:0 to left, 1 to the right
	bool gravity;//true:will drop
	bool dropping;
	int yOfs;//offset for floor tile detection
	byte flipCnt;
	nat tick;

	nat pathList; //Address of path list 
	byte pathStep;// Current index in path array
	byte pathMax;// Max index in path array

	byte spId;//from 13 to 16
	byte spRef;
}; 
	
type tweaponType {
	byte spFirstRef;
	int yOfs;
	bool gravity; // true if will drop
	bool bounce; // true bounce at start
	int flip; // 0: none, 1: Hflip if shoot from left 2: cyclic
	nat yStartL0; // Y coord at start for floor level X
	nat yStartL1;
	nat yStartL2;
};
	

type tplate {
	int X;
	int Y;
	//state:0:free,1:catched,2:on pole state 1,3:on pole st2,4:onpole st3
	//5:is falling
	byte state; 
	nat tState; //time has started current state(from state 2)
	byte poleNum; //pole num if state=2/3/4 (on pole)
	byte animCnt;
	nat tick;

	byte spId;//from 17 to 29
	byte spRef;
};

type tplatestateinterval {
	byte int1; //sec to state 2 to 3
	byte int2; //sec to state 3 to 4
	byte int3; //sec to plate fall
};

type tfallenplate {
	byte nplate;
	byte floor;
};

type twitchesparams {
	byte witchRndShow;//0: never 100:always
	byte witchRndShot;//0:never 100:always
	byte witchShotDelayMin; //min sec before shooting 
	byte witchShotDelayMax; //max sec before shooting
	byte weaponSpeed;
};

