// Functions

bool natInArray(nat addr,byte size,nat v) {
	for(byte i;i<size;i++)
		if (peekW(addr+(i*2))==v) return true;
	return false;
}

bool isFloor(nat r) {
	if (r==89||r==88||r==108||r==133||r==134||r==135||r==136||r==137||r==138||r==139||r==140)
		return true;
	if(r==141||r==142||r==143||r==144||r==145||r==90||r==109||r==146)
		return true;
	return false;
}

int strcmp(nat str1,nat str2) {        // compare 2 strings
	while (peek(str1) && peek(str1)==peek(str2)){
		str1++;
		str2++;
	}
	return (peek(str1)-peek(str2));
}


void musicReset() {
	musicCnt[0]=0;
	musicCnt[1]=0;    
	musicCounter[0]=0;
	musicCounter[1]=0;
   musicTick=0;
	ymNoteOff(0);    
	ymNoteOff(1);    
}

void musicStart()
{
	ymInit(0);
	ymVol(127);
	ymLoad("res/bell01.ins",0);
	musicReset();
}

		
void musicStop()
{
   ymNoteOff(0);    
	ymNoteOff(1);    
}

void musicUpd()
{
nat tadr;
nat t;

	if (musicPaused==true)
		return;

	if (musicTick>tick)
		return;
	

	for(byte i=0;i<2;i++) {
		if (i==0) tadr=&music1;
		else tadr=&music2;
		
		if(musicCounter[i]) {
			musicCounter[i]-=1;
			if (musicCounter[i]<0) musicCounter[i]=0;
			continue;
		}

		if(peek(tadr+musicCnt[i])==0) {
			musicCnt[i]=0;
		}
		if(peek(tadr+musicCnt[i])>100) {
			ymVoice(i,0,peek(tadr+musicCnt[i])-100,0b11,15);
			musicCnt[i]++;
		}
		
		ymNoteOn(i,peek(tadr+musicCnt[i]+1),27);
		
		musicCounter[i]=peek(tadr+musicCnt[i]);
		
		musicCnt[i]+=2;
	}
	musicTick = tick+4;	
}


void sndMngrReset() {
	for(byte i;i<2;i++) {
		sndTick[i]=0;
		sndReady[i]=true;
	}
	
}
void sndMngrSet(byte voice,byte nticks) {
	sndTick[voice]=tick+nticks;
	sndReady[voice]=false;
}

void sndMngrUpd() {
	for(byte i;i<2;i++) {
		if (sndReady[i]==false && sndTick[i]<tick) {
			sndReady[i]=true;
		}
	}
}


void soundBreak(byte voice){	
	synNoteOff(voice);
	synVoice(voice,2,5,0b11,15); //id,wform,octave,pan,volume
	synEnv(voice,0,10,0,0);//id,attack,delay,sustain,release
	synNoteOn(voice,48,120);//voice, note, velocity
}

void soundBounce(byte voice){
	
	synNoteOff(voice);
	synVoice(voice,0,7,0b11,15); //id,wform,octave,pan,volume
	synEnv(voice,0,10,0,0);//id,attack,delay,sustain,release
	synNoteOn(voice,1,120);//voice, note, velocity
}

void soundRun(byte voice){
	if (sndReady[voice]) {
		sndMngrSet(voice,10);
		synNoteOff(voice);
		synVoice(voice,0,2,0b11,10);
		synEnv(voice,2,2,0,10);
		synNoteOn(voice,100,120);
	}		
}

void soundCatch(byte voice){
	synInit(voice);
	synNoteOff(voice);
	synVoice(voice,1,4,0b11,15);
	synEnv(voice,6,2,0,10);
	synNoteOn(voice,97,120);
}
	
void soundRelease(byte voice){
	synInit(voice);
	synNoteOff(voice);
	synVoice(voice,1,4,0b11,15);
	synEnv(voice,6,10,0,10);
	synNoteOn(voice,80,120);
}	


void soundBeep(byte voice){
	if (sndReady[voice]) {
		synInit(voice);
		synNoteOff(voice);
		synVoice(voice,1,4,0b11,15);
		synEnv(voice,6,2,0,10);
		synNoteOn(voice,97,120);
		sndMngrSet(voice,1);
	}
}



void soundEvt(byte evt,byte voice)
{
	byte music1[25] ={
    55,20,
    57,10,
    55,10,
    57,10,
    55,10,
    52,9,
    50,10,
    52,9,
    55,10,
    52,9,
    50,10,
    52,30,
    255};

	byte music2[11] ={
    74,10,
    71,10,
    67,10,
    64,20,
    60,60,
    255};


	nat p;

	byte note;
	byte len;

	synInit(0);
	if (evt==1) {
		p=&music1;
		synEnv(voice,0,10,5,0);
		synVoice(voice,0,6,0b11,15);
	} else {
		p=&music2;
		synEnv(voice,0,10,5,0);
		synVoice(voice,0,4,0b11,15);
	}
	while(true){
		note=peek(p);
		if(note==255) break;
		p++;

		len=peek(p);
		p++;
		synNoteOn(voice,note,127);

		while(len>0){
			vSync();
			len--;
      }
		synNoteOff(voice);
	}
}

// "floor" functions

void floorClose(byte num) {
	poke(tilBuf+posFloor[num],tileFloorUp);
	poke(tilBuf+posFloor[num]+32,tileFloorDown);
}

void floorOpen(byte num) { //num from 0 to 9
	poke(tilBuf+posFloor[num],tileEmpty); 
	poke(tilBuf+posFloor[num]+32,tileEmpty);  
	poke(tilBuf+posFloor[num]-32,tileEmpty); //No pole at floor opening
	poles[num+5].state=0;// No upper pole 
	poles[num+5].animState=0;
}

// "pole" functions

void poleInit() {
	for(byte i;i<15;i++) {
		poke(tilBuf+poles[i].posTileDown,tilePole);
		poles[i].state=16;// normal pole
		poles[i].animState=16;
		poles[i].plateNum=100;
	}
}	


void poleSzUp(byte num,bool full) {//Pole from 0 to 15
	if (num<10 && full==true) {
		floorOpen(num);
		poles[num].state=48;
	} else { // last floor pole are 16 max and no top floor to open
		poles[num].state=16; 
		poles[num].animState=0;
		poke(tilBuf+poles[num].posTileDown,tileEmpty);//Erase pole
	}
	
}

void poleAnim(){
	nat posToChg;
	byte refToChg;
	// Tiles from 211 to 225, pole decreasing. Tile 80:full pole
	for(byte i;i<15;i++) {
		if(poles[i].state!=poles[i].animState){	
			// Current state different from state (to reach)
			if (poles[i].state>poles[i].animState) poles[i].animState++;
			else poles[i].animState--;
			if (poles[i].animState>=0 && poles[i].animState<=16) 
				posToChg=poles[i].posTileDown; // 0 to 16
			else if (poles[i].animState<=32) 
				posToChg=poles[i].posTileDown-32; // 17 to 32		
			else if (poles[i].animState<=48) 
				posToChg=poles[i].posTileDown-64; // 33 to 48

			
			if (poles[i].animState==0)
				refToChg=1; // no pole
			else {
				byte mod = poles[i].animState % 16;
				if (mod == 0) refToChg=80;
				else refToChg=(226-mod);
			}
			poke(tilBuf+posToChg,refToChg);

			if (poles[i].plateNum!=100) {
				//Extended pole has a plate on top:
				//we move the plate with the pole
				byte j;
				j=poles[i].plateNum;
				plates[j].Y=poles[i].Y-(poles[i].animState*2)+6;
				sprPos(plates[j].spId,plates[j].X,plates[j].Y);

			}

			if (poles[i].state == poles[i].animState) {
				if (poles[i].state ==48) {
					if (poles[i].plateNum!=100) {
						//Extended pole has a plate on top:
						//we move the plate on the upper pole
						byte j;
						j=poles[i].plateNum;
						poles[i+5].plateNum=j;
						poles[i].plateNum=100;
						plates[j].poleNum=i+5;
						plates[j].Y=poles[i+5].Y-90;
						sprPos(plates[j].spId,plates[j].X,plates[j].Y);
					}
					poleSzUp(i+5,false);
				}
			}
		}
	}
}

// "player" functions 

void playerInit() {
	player.X=329;
	player.Y=358;
	player.pathList=0;
	player.pathDir=0;
	player.pathStep=0;
	player.plateCatched=100; // id of catched plate. 100:none
	player.spRef=5; // Front view
	player.spId=31;
	sprRef(player.spId,5);
	sprPal(player.spId,0);
	sprPrio(player.spId,0);
	sprFlip(player.spId,false,false);
	sprPos(player.spId,329,358);
}

void _playerSetPos() {
	sprPos(player.spId,player.X,player.Y);
	soundRun(0);
	if (player.plateCatched!=100) {
		byte j;
		j=player.plateCatched;
		plates[j].X=player.X;
		plates[j].Y=player.Y-6;
		sprPos(plates[j].spId,plates[j].X,plates[j].Y);
	}
}

bool _isPlayerOnFl() {
	if (player.Y>=353 && player.Y<=393) {
		// Floor level 0
		player.Y=358;
		return true;
	}
	if (player.Y>=261 && player.Y<=271) {
		// Floor level 1
		player.Y=266;
		return true;
	}
	if (player.Y>=165 && player.Y<=175) {
		// Floor level 2
		player.Y=170;
		return true;
	}
	return false;
}

void playerGoR(byte n) {
	if (_isPlayerOnFl()) {
		if (rnd(0,2)==1) {
			if (player.spRef==6) player.spRef=7;
				else player.spRef=6;
		}
		sprFlip(player.spId,true,false);
		player.X+=n;
		if (player.X>530) player.X=530;
		sprRef(player.spId,player.spRef);
		_playerSetPos();
	}
}

void playerGoL(byte n) {
	if (_isPlayerOnFl()) {
		if (rnd(0,1)==1) {
			if (player.spRef==6) player.spRef=7;
				else player.spRef=6;
		}	
		sprFlip(player.spId,false,false);
		player.X-=n;
		if (player.X<130) player.X=130;
		sprRef(player.spId,player.spRef);
		_playerSetPos();
	}
}	

void playerGoU(byte n) {
	// Check if X pos is in scope of a pole
	for(byte i;i<15;i++) {
		if (player.X >= poles[i].X-8 && player.X <= poles[i].X+8) {
			if (player.Y <= (poles[i].Y+1) && player.Y >= poles[i].Y-(poles[i].state*2)) {
				if (rnd(0,1)==1) {
					if (player.spRef==8) player.spRef=9;
					else player.spRef=8;
					sprRef(player.spId,player.spRef);
				}
				if (poles[i].state==16 && poles[i].plateNum==100 && plateCatched==true && player.Y-1 <= poles[i].Y-(poles[i].state*2)) {
					byte k1;
					byte k2;
					byte k;
					byte j;
					
					// player is on top of this empty pole and has a plate
					poles[i].plateNum=player.plateCatched;
					j=player.plateCatched;
					
					plates[j].Y=player.Y+6;
					sprPos(plates[j].spId,plates[j].X,plates[j].Y);
					
					plates[j].state=2;
					plates[j].tState=_time;
					plates[j].poleNum=i;
					plates[j].animCnt=0;
					plates[j].tick=0;
					plateCatched=false;
					player.plateCatched=100;
					score+=plateScore[level];
					soundRelease(0);
					
					// Do we extend a pole and open upper floor?
					
					k1=100;
					
					if (i>=0 && i<5) { // First floor
						k1=0;
						k2=5;
					} else if (i<10) { // Second floor
						k1=5;
						k2=10;
					} else {
						k1=10;
						k2=15;
					}
					
					if (k1<100) {
						//Check if all poles of this floor have a plate
						//and open floor if needed
						for(k=k1;k<k2;k++)
							if (poles[k].plateNum==100) // no plate
								break;
						if (k==k2) {// all poles have a plate:extend a pole
							if (k1==10) { //Top floor: game level completed!
								levelCompleted=true;
								score+=bonusScore[level];
							} else {
								while(true) { // current pole cannot be extended
									k=rnd(k1,k2-1);
									if (k!=i)
										break;
								}
								poleSzUp(k,true);
							}
						}
					}			 
				} else if (poles[i].state==16 && poles[i].plateNum!=100 && player.Y <= poles[i].Y-(poles[i].state*2)) {
					//player is on top of a pole which has a plate
					sprRef(player.spId,19);
					player.spRef=19;

					// Reset plate timer
					byte j;
					j=poles[i].plateNum;
					plates[j].state=2;
					plates[j].tState=_time;
					plates[j].spRef=0;
					plates[j].animCnt=0;
					sprRef(plates[j].spId,0);
				}
				player.X=poles[i].X;
				player.Y-=n;
				_playerSetPos();

				return;
			} 
		}
	}
}

void playerGoD(byte n) {
	// Check if X pos is in scope of a pole
	for(byte i;i<15;i++) {
		if (player.X >= poles[i].X-8 && player.X <= poles[i].X+8) {
			if (player.Y <= poles[i].Y && player.Y >= poles[i].Y-(poles[i].state*2)-1) {
				player.X=poles[i].X;
				player.Y+=n;
				if (rnd(0,1)==1) {
					if (player.spRef==8) player.spRef=9;
					else player.spRef=8;
					sprRef(player.spId,player.spRef);
				}
				_playerSetPos();
				return;
			}
		}
	}
	// Couldn't go down: player kneel down 
	player.spRef=15;
	sprRef(player.spId,player.spRef);	
	if (player.plateCatched!=100) {
		// plate position down
		byte j;
		j=player.plateCatched;
		plates[j].X=player.X;
		plates[j].Y=player.Y;
		sprPos(plates[j].spId,plates[j].X,plates[j].Y);
	}

}
void playerJump(byte direction) {
	if (_isPlayerOnFl()) {
		player.pathDir=direction; //0:none 1:left 2:right
		player.pathList=&jumpC;
		if (direction==1) { // To the left: start at array end
			player.pathStep=(byte)#jumpC-1;
		} else {
			player.pathStep=0; 	
			player.pathMax=(byte)#jumpC;
		}
		if (direction==0) sprRef(player.spId,16);
		else sprRef(player.spId,4);
	}
}

bool playerAnim() {

	if (player.pathList==0) return false;
	if (player.pathDir==0 || player.pathDir==2) { // None or to the right
		if (player.pathDir==2) player.X++;
		player.Y+=(int)peekW(player.pathList+(player.pathStep*2));	
		player.pathStep++;
		if (player.pathStep == player.pathMax) {
			player.pathList=0;
			if (player.pathDir==2)
				sprRef(player.spId,6);
			else sprRef(player.spId,5);
		}
	} else { // To the left
		player.X--;		
		player.Y+=-(int)peekW(player.pathList+(player.pathStep*2));
		player.pathStep--;
		if (player.pathStep == 0) {
			player.pathList=0;
			sprRef(player.spId,6);
		}
	}
	if (player.X>530) player.X=530;
	else if (player.X<130) player.X=130;
	_playerSetPos();
	return true;
}

// "weapon" functions 

void weaponInit() {
	for(byte i;i<#weapon;i++) {
		weapon[i].X=0;
		weapon[i].Y=0;
		weapon[i].wtype=0;
		weapon[i].dir=0;
		weapon[i].gravity=false;
		weapon[i].yOfs=0;
		weapon[i].flipCnt=0;
		weapon[i].tick=0;
		weapon[i].dropping=false;
		weapon[i].pathList=0;
		weapon[i].pathStep=0;
		weapon[i].spId=13+i;
		weapon[i].spRef=14;			
		sprPal(weapon[i].spId,0);
		sprPrio(weapon[i].spId,0);
		sprFlip(weapon[i].spId,false,false);
		sprPos(weapon[i].spId,0,0);
	}
}
	
void weaponStart(byte level,byte side) {
	// level 0 (ground) to 2(top)
	// side 0:from left, 1:from right

	for(byte i;i<#weapon;i++) {
		if(weapon[i].X==0) {
			weapon[i].wtype = rnd(0,#weapontype-1);
			byte j = weapon[i].wtype; // BUG:NEED A VAR
			weapon[i].spRef=weapontype[j].spFirstRef;
			weapon[i].yOfs=weapontype[j].yOfs;
			weapon[i].gravity=weapontype[j].gravity;
			weapon[i].dropping=false;
			weapon[i].pathList=0;
			weapon[i].pathStep=0;
			weapon[i].dir=(byte)(1-side);
			if (weapontype[j].bounce==true) {
				weapon[i].pathList=&bounceC;
				if (weapon[i].dir==0) // To the left: start at array end
					weapon[i].pathStep=(byte)#bounceC-1;
				else {
					weapon[i].pathStep=0;
					weapon[i].pathMax=(byte)#bounceC;
				}
			}
			if (level==0) weapon[i].Y=weapontype[j].yStartL0;
			else if (level==1) weapon[i].Y=weapontype[j].yStartL1;
			else weapon[i].Y=weapontype[j].yStartL2;
			if (side==0) weapon[i].X=140;
			else weapon[i].X=520;
			sprRef(weapon[i].spId,weapon[i].spRef);
			weapon[i].flipCnt=100;
			weapon[i].tick=0;
			if (side==0 && weapontype[j].flip==1) // Reverse
				sprFlip(weapon[i].spId,true,false);
			else {
				sprFlip(weapon[i].spId,false,false);
				if (weapontype[j].flip==2) //Cyclic
					weapon[i].flipCnt=0;
			}
			sprPos(weapon[i].spId,weapon[i].X,weapon[i].Y);
			return;
		}
	}
}

void weaponAnim() {	
	byte wspeed=witchesParams[level].weaponSpeed;
	for(byte i;i<#weapon;i++) {
		if(weapon[i].X>0) {
			if (weapon[i].dir==0) { // to the left
				weapon[i].X-=wspeed;
				if (weapon[i].pathList!=0) {
					weapon[i].Y+=-(int)peekW(weapon[i].pathList+(weapon[i].pathStep*2));
					weapon[i].pathStep--;
					if (weapon[i].pathStep == 0) {
						weapon[i].pathList=0;
					}
				}
			} else { // To the right
				weapon[i].X+=wspeed;
				if (weapon[i].pathList!=0) {
					weapon[i].Y+=(int)peekW(weapon[i].pathList+(weapon[i].pathStep*2));
					weapon[i].pathStep++;
					if (weapon[i].pathStep == weapon[i].pathMax) {
						weapon[i].pathList=0;
					}
				}
			}
			if (weapon[i].X<112 || weapon[i].X>545) {
				weapon[i].X=0;
				weapon[i].Y=0;
			} else {
				if (weapon[i].gravity==true && weapon[i].pathList==0) {
					int x;
					int y;
					byte r;
					if (weapon[i].dir==0)  // to the left
						x=weapon[i].X+40-42; // right border(24px)-4px (in subpx)
					else x=weapon[i].X+8-42;	

					y = weapon[i].Y+weapon[i].yOfs-48;


					for(byte j=1;j<=4*wspeed;j++ ) {
						r=tileGetRef(x,y+j);
						if (isFloor(r)==false) {
							// No floor
							weapon[i].Y+=1;
							weapon[i].dropping=true;
						} else {	
							// Floor
							if (weapon[i].dropping==true) {
								// Was dropping:will bounce	
								weapon[i].pathList=&bounceC;
								if (weapon[i].dir==0) { // To the left: start at array end
									weapon[i].pathStep=(byte)#bounceC-1;
								} else {
									weapon[i].pathStep=0; 	
									weapon[i].pathMax=(byte)#bounceC;
								}	
								soundBounce(1);							
									
							}
							weapon[i].dropping=false;
							break;
						}
					}
				
				}
				if (weapon[i].tick<tick && weapon[i].flipCnt!=100) {
					if(weapon[i].flipCnt==0)
						sprFlip(weapon[i].spId,false,false);
					else if(weapon[i].flipCnt==1)
						if(weapon[i].dir==0) //to the left
							sprFlip(weapon[i].spId,true,false);
						else sprFlip(weapon[i].spId,false,true);
					else if(weapon[i].flipCnt==2)
						sprFlip(weapon[i].spId,true,true);
					else if(weapon[i].flipCnt==3)
						if(weapon[i].dir==0) //to the left
							sprFlip(weapon[i].spId,false,true);
						else sprFlip(weapon[i].spId,true,false);
					weapon[i].flipCnt++;
					if (weapon[i].flipCnt==4) weapon[i].flipCnt=0;
					weapon[i].tick=tick+20;
				}
			}
			sprPos(weapon[i].spId,weapon[i].X,weapon[i].Y);
		}
	}
	
}

// "witch" functions

void witchInit() {
	for(byte i;i<maxWitches;i++){
		witches[i].level=0;
		witches[i].side=0;
		witches[i].state=0;
		witches[i].willShot=false;
		witches[i].showTime=0;
		witches[i].shootTime=0;
		witches[i].spIdHead1=1+(3*i);
		witches[i].spIdHead2=2+(3*i);
		witches[i].spIdBody=3+(3*i);
		witches[i].spRefHead1=11;
		witches[i].spRefHead2=12;
		witches[i].spRefBody=13;
		sprRef(witches[i].spIdHead1,witches[i].spRefHead1);
		sprPal(witches[i].spIdHead1,0);
		sprPrio(witches[i].spIdHead1,0);
		sprFlip(witches[i].spIdHead1,false,false);
		sprPos(witches[i].spIdHead1,0,0);

		sprRef(witches[i].spIdHead2,witches[i].spRefHead2);
		sprPal(witches[i].spIdHead2,0);
		sprPrio(witches[i].spIdHead2,0);
		sprFlip(witches[i].spIdHead2,false,false);
		sprPos(witches[i].spIdHead2,0,0);

		sprRef(witches[i].spIdBody,witches[i].spRefBody);
		sprPal(witches[i].spIdBody,0);
		sprPrio(witches[i].spIdBody,0);
		sprFlip(witches[i].spIdBody,false,false);
		sprPos(witches[i].spIdBody,0,0);

	}	
}	


	
void witchActivate() {
	nat y;
	nat x;
	byte side;
	byte level;
	
	
	// Add new witch?
	if (timeWitch<_time && currWitches < maxCurrWitches) {
		timeWitch=_time+1;
		if (rnd(0,100)<witchRndShow) {
			for (byte i;i<maxWitches;i++){
				if(witches[i].state==0) {
					witches[i].showTime=_time;
					currWitches++;
					if (rnd(0,100)<witchRndShot) {
						witches[i].willShot=true;
					} else {
						witches[i].willShot=false;
					}
					witches[i].shootTime=_time+rnd(witchShotDelayMin,witchShotDelayMax);
					while(true) {
						level = rnd(0,2);
						side = rnd(0,1);
						// Is this place free?
						byte j;
						for(j=0;j<maxWitches;j++){
							if (witches[j].state!=0 && witches[j].level==level && witches[j].side==side)
								break;
						}
						if (j==maxWitches)
							break;
					}
					witches[i].side=side;
					witches[i].level=level;
					if (side==1) {
						sprFlip(witches[i].spIdHead1,true,false);
						sprFlip(witches[i].spIdHead2,true,false);
						sprFlip(witches[i].spIdBody,true,false);
					} else {
						sprFlip(witches[i].spIdHead1,false,false);
						sprFlip(witches[i].spIdHead2,false,false);
						sprFlip(witches[i].spIdBody,false,false);
					}
					witches[i].state=1; //we show just the head at first anyway
					if (level==0) y=345;
					else if (level==1) y=253;
					else if (level==2) y=157;
					if (side==0) x=148;
					else x=515;
					sprPos(witches[i].spIdHead1,x,y);
					break;
				}
			}

		}
	}
	// Manage current witches
	for (byte i;i<maxWitches;i++){
		if(witches[i].state>0) {
			if (witches[i].state == 1) {
				if (witches[i].shootTime<_time) {
					if (witches[i].willShot == true) {
						//Let's shot
						if (witches[i].level==0) y=345;
						else if (witches[i].level==1) y=253;
						else if (witches[i].level==2) y=157;
						if (witches[i].side==0) x=148;
						else x=515;
						sprPos(witches[i].spIdHead2,x,y);
						sprPos(witches[i].spIdBody,x,y+32);
						witches[i].state=2;
						weaponStart(witches[i].level,witches[i].side);
					} else {
						//we remove the witch
						sprPos(witches[i].spIdHead1,0,0);
						witches[i].state=0;
						currWitches--;
					}
				}
			} else if (witches[i].state == 2) {
				if (witches[i].shootTime+3<_time) {
					//After 3sec, we remove this bitch
					sprPos(witches[i].spIdHead1,0,0);
					sprPos(witches[i].spIdHead2,0,0);
					sprPos(witches[i].spIdBody,0,0);
					witches[i].state=0;
					currWitches--;
				}
			}
		}
	}
}	

// "plate" functions

void _plateInit(byte i) {
	plates[i].state=0;
	plates[i].poleNum=0;
	plates[i].animCnt=0;
	plates[i].tick=0;
	plates[i].spId=17+i;
	plates[i].spRef=3;
	plates[i].tState=0;
	sprRef(plates[i].spId,3);
	sprFlip(plates[i].spId,false,false);
}



void platePush(byte nplate,byte floor,byte side) {
	// floor(3)/side(2)/num(5):plateStack[floor * (2*5) + side*5 + num]
	byte i;
	byte j;
	i=(floor*10) + (side*5);
	for(j=i;j<(i+5);j++) {
		if (pStack[j]==100)
			break;
	}
	if (j==(i+5)) // Too many plates (impossible)
		return;
	pStack[j]=nplate;
	j=j-i;
	if(side==0) { // to the left
		plates[nplate].X=130;
		plates[nplate].Y=5*(5-j);
	} else {
		plates[nplate].X=530;
		plates[nplate].Y=5*(5-j);	
	}
	if (floor==0) plates[nplate].Y+=345;
	else if (floor==1) plates[nplate].Y+=252;
	else plates[nplate].Y+=156;
	plates[nplate].state=0;
	sprRef(plates[nplate].spId,3);
	sprFlip(plates[nplate].spId,false,false);
	sprPos(plates[nplate].spId,plates[nplate].X,plates[nplate].Y);
}

byte getFirstPlate(byte floor,byte side) {
	byte i;
	byte j;
	i=(floor*10) + (side*5);
	for(j=i;j<(i+5);j++) {
		if (pStack[j]==100) {
			if (j==i)  //no plate available
				return 100;
			return pStack[j-1];
		}
	}
	return pStack[j-1];
}

void plateRemove(byte nplate) {
	for(byte i=0;i<30;i++)
		if (pStack[i]==nplate) {
			pStack[i]=100;
			return;
		}
}

void plateInit() {
	
	for(byte i;i<13;i++) {
		_plateInit(i);
	}
	for(byte i;i<30;i++) {
		pStack[i]=100;
	}
	
	byte nplate;
	for (byte i;i<=2;i++) {
		byte n;
		if (i==0) n=5; // 5 plates on floor level 0
		else n=4;// 4 plates on floor level 1 & 2
		for (byte j=0;j<n;j++) {
			platePush(nplate,i,(byte)rnd(0,1));
			nplate++;
		}
	
	}	
}

void plateAnim(){
	for(byte i;i<13;i++) {
		// Animations
		if (plates[i].state>=2 && plates[i].tick<tick) {
			if (plates[i].state==2) {
				if (plates[i].animCnt==0) 
					sprFlip(plates[i].spId,false,false);
				else sprFlip(plates[i].spId,true,false);
				plates[i].animCnt=1-plates[i].animCnt;
			} else if (plates[i].state==3) {
				if (plates[i].animCnt==0) {
					sprFlip(plates[i].spId,false,false);
					sprRef(plates[i].spId,0);
				} else if (plates[i].animCnt==1) {
					sprRef(plates[i].spId,1);
				} else if (plates[i].animCnt==2) {
					sprFlip(plates[i].spId,true,false);
				} else if (plates[i].animCnt==3) {
					sprRef(plates[i].spId,0);
				}
				plates[i].animCnt++;
				if (plates[i].animCnt==4) plates[i].animCnt=0;
			} else if (plates[i].state==4){
				if (plates[i].animCnt==0) {
					sprFlip(plates[i].spId,false,false);
					sprRef(plates[i].spId,0);
				} else if (plates[i].animCnt==1) {
					sprRef(plates[i].spId,1);
				} else if (plates[i].animCnt==2) {
					sprRef(plates[i].spId,2);
				} else if (plates[i].animCnt==3) {
					sprFlip(plates[i].spId,true,false);
				} else if (plates[i].animCnt==4) {
					sprRef(plates[i].spId,1);
				} else if (plates[i].animCnt==5) {
					sprRef(plates[i].spId,0);
				}
				plates[i].animCnt++;
				if (plates[i].animCnt==6) plates[i].animCnt=0;
			} else {
				nat maxY;
				byte floor;
				if (i<5) { 
					maxY=358;
					floor=0;
				} else {
					byte num;
					num = i-5;
					if (peek(tilBuf+posFloor[num])==tileEmpty) 
						if(num>=0 && num<5) {
							maxY=358;
							floor=0;
						} else {
							maxY=266;
							floor=1;
						}	
					else 
						if(num>=0 && num<5) {
							maxY=266;
							floor=1;
						} else {
							maxY=170;
							floor=2;
						}
				}
				
				plates[i].Y+=2;
				if (plates[i].Y>=maxY) {
					byte j;
					isDead=true;
					fallenPlate.nplate=i;
					fallenPlate.floor=floor;
					j=plates[i].poleNum;
					poles[j].plateNum=100;
					sprRef(plates[i].spId,18);
					soundBreak(0);
				}
				sprPos(plates[i].spId,plates[i].X,plates[i].Y);
				
			
			}
			plates[i].tick=tick+1;
		}
		
		// State change
		if (plates[i].state>=2) {
			if (plates[i].state==2 && plates[i].tState+plateStateInterval[level].int1<=_time) {
				plates[i].state=3;
				plates[i].tState=_time;
			} else if (plates[i].state==3  && plates[i].tState+plateStateInterval[level].int2<=_time) {
				plates[i].state=4;
				plates[i].tState=_time;
			} else if (plates[i].state==4  && plates[i].tState+plateStateInterval[level].int3<=_time) {
				plates[i].state=5;
			}
		}
	}	
}
// Misc functions

void initLevel() {
	maxCurrWitches=4; // No more than 4
	currWitches=0;
	plateCatched=false;
	fallenPlate.nplate=100;
	timeWitch=0;
	
	witchRndShow=witchesParams[level].witchRndShow;
	witchRndShot=witchesParams[level].witchRndShot;
	witchShotDelayMin=witchesParams[level].witchShotDelayMin;
	witchShotDelayMax=witchesParams[level].witchShotDelayMax;


	levelAccess[0]=false;
	levelAccess[1]=false;
	isDead=false;
	levelCompleted=false;
}

void clearSprites() {
	for (byte i=0;i<32;i++) {
		sprPos(i,0,0);
		sprFlip(i,false,false);
		sprPrio(i,0);
	}
}

void clearTiles(){
	memSet(tilBufA,512,0);//Clear tiles buffer A
	memSet(tilBufB,512,0);//Clear tiles buffer B
}

void clearTileSet(){
	memSet(cpuWindow,32768,0,0);//Clear tileset
}

void clearBitMap(){
	memSet(cpuWindow,48000,0,bmpPage);// Efface bitmap
}



void sleep(nat msec) {
	clkSet();
	while(_mSec<msec){}
}



void cls() {
	memSet(0x1200,3200,32); //clear screen content
	memSet(0x1e80,3200,1); //clear screen colors
}

void correctTime(nat sec) {
	byte i;
	for(i=0;i<4;i++) {
		if (witches[i].showTime>0)
			witches[i].showTime+=sec;
		if (witches[i].shootTime>0)
			witches[i].shootTime+=sec;
	}
	for(i=0;i<13;i++) {
		if (plates[i].tState>0)
			plates[i].tState+=sec;
	}	
}

void pause() {
	if (_keyDwn == 66) {
		nat sec=_time;
		sleep(300);
		while(_keyDwn==0) {}
		sleep(150);
		correctTime(_time-sec);
	}
}

void int2Txt(nat val,byte len)
{
	nat rank=1;
	for(int n=len-1; n>=0; n--)
	{
		byte digit = (byte)((val%(10*rank))/rank);
		poke(&i2t+(byte)n,digit+48);
		rank*=10;
	}
	poke(&i2t+len,0);
}
			
void drawBackground() {
	poke(gfxModes,peek(gfxModes) & 0b11111110);//Disable bitmap display
	fileName=bg[level];
	concat(fileName,".pal");
	import(fileName,0x11a0,48);
	fileName=bg[level];
	concat(fileName,".bmp");
	import(fileName,cpuWindow,48000,bmpPage);
	poke(gfxModes,peek(gfxModes) | 0b00000001); //Enable bitmap display
}

void selectTileBuffer(byte buf) {
	if (buf==0) {
		// Buffer A
		poke(0x2f0b,peek(0x2f0b) & 0b11111011);
	} else {
		// Buffer B
		poke(0x2f0b,peek(0x2f0b) | 0b00000100);
	}
}

void setTile(byte buf,byte ref,byte x,byte y) {
	nat addr;
	nat tilBuff;
	
	if (buf==0)
		tilBuff = tilBufA;
	else
		tilBuff = tilBufB;
	addr = tilBuff + y*32 + x;
	poke(addr,ref,0);
}
	
void drawTemple() {
	poke(gfxModes,peek(gfxModes) & 0b11110111);//Disable tiles display

	cls();
	clearTiles();
	clearTileSet();			
	
	
	import("res/tmpl.tls",cpuWindow,0,tilPage);
	import("res/tmpl-cpl.tls",cpuWindow+27008,1920,tilPage);
	import("res/tmpl.pal",tilPal,48);
	import("res/tmpl.map",tilBuf,480);

	poke(tilBuf+133,tileEmpty);
	poke(tilBuf+229,tileEmpty);
	poke(tilBuf+197,tileFloorDown);
	
	poke(gfxModes,peek(gfxModes) | 0b00001000); //Enable tiles display
	
}

